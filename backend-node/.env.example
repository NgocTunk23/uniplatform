# --- SERVER CONFIGURATION ---
PORT=5001 # Cổng chạy server (Mặc định 5001 để tránh xung đột AirPlay trên macOS)
NODE_ENV=development # Môi trường chạy (development/production/test)

# --- DATABASE CONFIGURATION (MongoDB) ---
# Yêu cầu MongoDB Replica Set để hỗ trợ Prisma Transactions
MONGO_URI=mongodb://root:password@localhost:27017/uniplatform?authSource=admin&replicaSet=rs0

# --- AUTHENTICATION ---
JWT_SECRET=your_super_secret_jwt_key_here # Khóa bí mật để ký JWT Token
JWT_EXPIRES_IN=7d # Thời hạn của Token

# --- GOOGLE DRIVE INTEGRATION ---
# Xem hướng dẫn chi tiết lấy các thông số này trong README.md
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:5001/api/auth/google/callback
GOOGLE_DRIVE_REFRESH_TOKEN=your_oauth2_refresh_token
GOOGLE_DRIVE_FOLDER_ID=your_specific_drive_folder_id_to_store_files

# Điều khiển chế độ giả lập GDrive (true: không upload thật, false: upload thật)
GOOGLE_DRIVE_MOCK=false

# --- AI INTEGRATION (GEMINI) ---
# Lấy API Key tại: https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here
